# OPD Panel — copy to .env and fill in values

# Daemon socket path
OPD_SOCKET=/var/run/opd/opd.sock

# SQLite database path
OPD_DB_PATH=/var/lib/opd/opd.db

# Agent
OPD_AGENT_URL=http://127.0.0.1:7070
OPD_AGENT_SECRET=change_me_generated_by_install_sh

# Servers base directory
OPD_SERVERS_DIR=/var/lib/opd/servers

# Cache directory
OPD_CACHE_DIR=/var/lib/opd/cache

# Playit.gg agent binary path (optional)
OPD_PLAYIT_BIN=/usr/local/bin/playit

# DuckDNS (optional)
OPD_DUCKDNS_TOKEN=
OPD_DUCKDNS_DOMAIN=

# Log level: debug | info | warn | error
OPD_LOG_LEVEL=info
